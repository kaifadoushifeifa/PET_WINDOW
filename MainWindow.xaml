<Window x:Class="PetWindow.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PetWindow"
        Width="220"
        Height="260"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True">
  <Grid x:Name="RootGrid" Background="Transparent">
    <Grid.LayoutTransform>
      <ScaleTransform x:Name="RootScale" ScaleX="1" ScaleY="1"/>
    </Grid.LayoutTransform>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto"/>
      <ColumnDefinition Width="*" MinWidth="96"/>
      <ColumnDefinition Width="Auto"/>
    </Grid.ColumnDefinitions>

    <!-- 宠物隐藏时仍可右键：底层整块微弱 Alpha 参与命中 -->
    <Border Grid.ColumnSpan="3"
            Background="#01000000"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"/>

    <Border x:Name="SidePanelLeft"
            Grid.Column="0"
            VerticalAlignment="Center"
            Margin="0,0,6,0"
            Padding="6,4"
            CornerRadius="6"
            Background="#CC1E1E1E"
            Visibility="Collapsed">
      <StackPanel>
        <TextBlock x:Name="TxtTime" Foreground="White" FontSize="11"/>
        <TextBlock x:Name="TxtWeather" Foreground="#CCCCCC" FontSize="10" Margin="0,2,0,0"/>
      </StackPanel>
    </Border>

    <Border x:Name="PetHitArea"
            Grid.Column="1"
            Background="Transparent"
            MinWidth="128"
            MinHeight="160"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
    <Viewbox x:Name="PetHost"
             Stretch="Uniform"
             HorizontalAlignment="Center"
             VerticalAlignment="Center">
      <Grid Width="128" Height="160">
        <Image x:Name="PetImage"
               Stretch="Uniform"
               RenderOptions.BitmapScalingMode="HighQuality"
               IsHitTestVisible="True"/>
        <!-- 无皮肤资源时的矢量占位 -->
        <Canvas x:Name="FallbackPet" Width="128" Height="160" Visibility="Collapsed">
          <Ellipse Canvas.Left="24" Canvas.Top="40" Width="80" Height="90" Fill="#FFF6B26A" Stroke="#FF8B4513" StrokeThickness="2"/>
          <Ellipse Canvas.Left="40" Canvas.Top="58" Width="14" Height="18" Fill="Black"/>
          <Ellipse Canvas.Left="74" Canvas.Top="58" Width="14" Height="18" Fill="Black"/>
          <Ellipse Canvas.Left="52" Canvas.Top="88" Width="24" Height="12" Fill="#FFFF9090"/>
          <Ellipse Canvas.Left="48" Canvas.Top="18" Width="16" Height="28" Fill="#FFF6B26A" Stroke="#FF8B4513" StrokeThickness="1"/>
          <Ellipse Canvas.Left="64" Canvas.Top="18" Width="16" Height="28" Fill="#FFF6B26A" Stroke="#FF8B4513" StrokeThickness="1"/>
        </Canvas>
      </Grid>
    </Viewbox>
    </Border>

    <Border x:Name="SidePanelRight"
            Grid.Column="2"
            VerticalAlignment="Center"
            Margin="6,0,0,0"
            Padding="6,4"
            CornerRadius="6"
            Background="#CC1E1E1E"
            Visibility="Collapsed">
      <TextBlock x:Name="TxtNet" Foreground="White" FontSize="11" TextWrapping="Wrap" MaxWidth="100"/>
    </Border>

    <Popup x:Name="BubblePopup"
           Grid.ColumnSpan="3"
           AllowsTransparency="True"
           PlacementTarget="{Binding ElementName=PetHitArea}"
           Placement="Top"
           HorizontalOffset="0"
           VerticalOffset="-8"
           StaysOpen="False">
      <Border Background="#FFFFFDE7"
              BorderBrush="#FFFFC107"
              BorderThickness="1"
              CornerRadius="8"
              Padding="10,6"
              MaxWidth="220">
        <TextBlock x:Name="BubbleText" Foreground="#333" FontSize="12" TextWrapping="Wrap"/>
      </Border>
    </Popup>
  </Grid>
</Window>
