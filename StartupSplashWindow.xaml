<Window x:Class="PetWindow.StartupSplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="奥比时光"
        Width="480"
        Height="220"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Topmost="True">
  <Border x:Name="Card"
          CornerRadius="20"
          Padding="40,36"
          BorderThickness="1.5"
          BorderBrush="#99d4a574">
    <Border.Background>
      <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F2fff8f0" Offset="0"/>
        <GradientStop Color="#F2ffe8d4" Offset="0.45"/>
        <GradientStop Color="#F2ffd4b8" Offset="1"/>
      </LinearGradientBrush>
    </Border.Background>
    <Border.Effect>
      <DropShadowEffect BlurRadius="32" ShadowDepth="6" Direction="270" Opacity="0.35" Color="#FF8b4513"/>
    </Border.Effect>
    <StackPanel VerticalAlignment="Center">
      <TextBlock x:Name="TitleText"
                 Text="奥比时光"
                 FontSize="40"
                 FontWeight="SemiBold"
                 HorizontalAlignment="Center"
                 Foreground="#FF6b4428">
        <TextBlock.Effect>
          <DropShadowEffect BlurRadius="2" ShadowDepth="1" Direction="270" Opacity="0.25" Color="#FFFFFFFF"/>
        </TextBlock.Effect>
      </TextBlock>
      <TextBlock Text="桌面宠物 · 正在唤醒"
                 FontSize="13"
                 Foreground="#996b4428"
                 HorizontalAlignment="Center"
                 Margin="0,14,0,0"/>
    </StackPanel>
  </Border>
</Window>
