<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- 柔和磨砂卡片风：低饱和背景 + 圆角药丸按钮 + 薄荷点缀 -->

  <SolidColorBrush x:Key="HudPanelBg" Color="#DD242830"/>
  <SolidColorBrush x:Key="HudPanelBorder" Color="#5599b8d4"/>
  <SolidColorBrush x:Key="HudAccent" Color="#FF7dd3c0"/>
  <SolidColorBrush x:Key="HudAccentSoft" Color="#FF5aab9a"/>
  <SolidColorBrush x:Key="HudText" Color="#FFeef2f8"/>
  <SolidColorBrush x:Key="HudTextMuted" Color="#FFa8b4c8"/>

  <LinearGradientBrush x:Key="HudBtnIdle" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FF3a424f" Offset="0"/>
    <GradientStop Color="#FF2d343f" Offset="1"/>
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="HudBtnHover" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FF4d5666" Offset="0"/>
    <GradientStop Color="#FF383f4d" Offset="1"/>
  </LinearGradientBrush>

  <LinearGradientBrush x:Key="HudBtnPressed" StartPoint="0,0" EndPoint="0,1">
    <GradientStop Color="#FF323843" Offset="0"/>
    <GradientStop Color="#FF252a33" Offset="1"/>
  </LinearGradientBrush>

  <Style x:Key="GameHudPanelBorder" TargetType="Border">
    <Setter Property="Background" Value="{StaticResource HudPanelBg}"/>
    <Setter Property="BorderBrush" Value="{StaticResource HudPanelBorder}"/>
    <Setter Property="BorderThickness" Value="1"/>
    <Setter Property="CornerRadius" Value="14"/>
    <Setter Property="Padding" Value="12,10"/>
    <Setter Property="Effect">
      <Setter.Value>
        <DropShadowEffect BlurRadius="24" ShadowDepth="3" Direction="270" Opacity="0.35" Color="#FF000000"/>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="GameHudTitle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{StaticResource HudAccent}"/>
    <Setter Property="FontWeight" Value="SemiBold"/>
    <Setter Property="FontSize" Value="13"/>
    <Setter Property="HorizontalAlignment" Value="Center"/>
    <Setter Property="Margin" Value="0,2,0,8"/>
  </Style>

  <Style x:Key="GameHudSep" TargetType="Border">
    <Setter Property="Height" Value="1"/>
    <Setter Property="Margin" Value="8,6"/>
    <Setter Property="CornerRadius" Value="1"/>
    <Setter Property="Opacity" Value="0.45"/>
    <Setter Property="Background" Value="{StaticResource HudPanelBorder}"/>
  </Style>

  <Style x:Key="GameHudButton" TargetType="Button">
    <Setter Property="Foreground" Value="{StaticResource HudText}"/>
    <Setter Property="FontSize" Value="12"/>
    <Setter Property="FontWeight" Value="Medium"/>
    <Setter Property="Padding" Value="14,8"/>
    <Setter Property="Margin" Value="0,3"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Border x:Name="Bd"
                  CornerRadius="10"
                  BorderThickness="1"
                  BorderBrush="#33485966"
                  Background="{StaticResource HudBtnIdle}"
                  Padding="{TemplateBinding Padding}">
            <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{StaticResource HudBtnHover}"/>
              <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource HudAccent}"/>
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
              <Setter TargetName="Bd" Property="Background" Value="{StaticResource HudBtnPressed}"/>
              <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource HudAccentSoft}"/>
            </Trigger>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Bd" Property="Opacity" Value="0.5"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="GameHudToggle" TargetType="ToggleButton" BasedOn="{StaticResource {x:Type ToggleButton}}">
    <Setter Property="Foreground" Value="{StaticResource HudText}"/>
    <Setter Property="FontSize" Value="11.5"/>
    <Setter Property="Padding" Value="12,7"/>
    <Setter Property="Margin" Value="0,3"/>
    <Setter Property="Cursor" Value="Hand"/>
    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="ToggleButton">
          <Border x:Name="TBd"
                  CornerRadius="10"
                  BorderThickness="1"
                  BorderBrush="#33485966"
                  Background="{StaticResource HudBtnIdle}"
                  Padding="{TemplateBinding Padding}">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <Ellipse x:Name="Led" Width="9" Height="9" Margin="0,0,10,0"
                       VerticalAlignment="Center"
                       Fill="#FF4a5566" Stroke="#FF586674" StrokeThickness="1"/>
              <ContentPresenter Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left"/>
            </Grid>
          </Border>
          <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
              <Setter TargetName="Led" Property="Fill" Value="{StaticResource HudAccent}"/>
              <Setter TargetName="Led" Property="Stroke" Value="{StaticResource HudAccentSoft}"/>
              <Setter TargetName="TBd" Property="BorderBrush" Value="{StaticResource HudAccent}"/>
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="TBd" Property="Background" Value="{StaticResource HudBtnHover}"/>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="GameHudMenuScroll" TargetType="ScrollViewer">
    <Setter Property="HorizontalScrollBarVisibility" Value="Disabled"/>
    <Setter Property="VerticalScrollBarVisibility" Value="Auto"/>
    <Setter Property="MaxHeight" Value="268"/>
    <Setter Property="Margin" Value="0,4,0,0"/>
  </Style>

</ResourceDictionary>
